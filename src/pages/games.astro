---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// Fetch all entries in the 'games' collection
const games = await getCollection('games') as CollectionEntry<'games'>[];
---
<BaseLayout title="Games – Castaway Studios">
  <h1 class="text-3xl font-bold text-center my-8">Our Games</h1>

  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {games.map((game) => (
        <a
          href={`/games/${game.slug}`}
          class="block bg-white rounded-lg overflow-hidden shadow hover:shadow-lg transition"
        >
          <img
            src={game.data.coverImage}
            alt={game.data.title}
            class="w-full h-48 object-cover"
          />
          <div class="p-4">
            <h2 class="text-xl font-semibold">{game.data.title}</h2>
            <p class="text-sm text-gray-600 mt-1">
              {game.data.description}
            </p>
            <p class="mt-2 text-xs text-gray-500">
              Release: {new Date(game.data.releaseDate).toLocaleDateString()}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
