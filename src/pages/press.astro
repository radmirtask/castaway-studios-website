---
/** @ts-nocheck */
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Load all press posts, sorted by date descending
const posts = (await getCollection('press'))
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---
<Layout title="Press & News – Castaway Studios">
  <h1 class="text-3xl font-bold text-center my-8">Press & News</h1>
  <div class="container mx-auto px-4 space-y-6">
    {posts.map((post) => (
      <a
        href={`/press/${post.slug}`}
        class="block md:flex items-center gap-6 p-6 border rounded-lg hover:shadow-lg transition"
      >
        {post.data.coverImage && (
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            class="w-full md:w-48 h-32 object-cover rounded"
          />
        )}
        <div>
          <h2 class="text-2xl font-semibold">{post.data.title}</h2>
          <p class="text-gray-500 text-sm">
            {new Date(post.data.date).toLocaleDateString()} ·{' '}
            {post.data.tags?.join(', ')}
          </p>
          <p class="mt-2 text-gray-700">{post.data.excerpt}</p>
        </div>
      </a>
    ))}
  </div>
</Layout>
