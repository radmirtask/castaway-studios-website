---
import Layout from '../layouts/Layout.astro';

const positions = [
  {
    title: "Senior Game Developer",
    department: "Engineering",
    location: "Remote / Hybrid",
    type: "Full-time",
    description: "Join our core development team to create innovative gaming experiences using cutting-edge technologies.",
    requirements: [
      "5+ years of game development experience",
      "Strong proficiency in C++ and Unreal Engine",
      "Experience with multiplayer game development",
      "Passion for creating immersive gaming experiences"
    ]
  },
  {
    title: "Game Designer",
    department: "Design",
    location: "Remote / Hybrid",
    type: "Full-time",
    description: "Shape the future of our games by designing engaging gameplay mechanics and compelling narratives.",
    requirements: [
      "3+ years of game design experience",
      "Strong portfolio of game design work",
      "Experience with level design and game balancing",
      "Excellent communication and documentation skills"
    ]
  },
  {
    title: "3D Artist",
    department: "Art",
    location: "Remote / Hybrid",
    type: "Full-time",
    description: "Create stunning visual assets that bring our game worlds to life.",
    requirements: [
      "3+ years of 3D modeling and texturing experience",
      "Proficiency in Maya, Blender, or similar tools",
      "Strong understanding of game art pipelines",
      "Portfolio demonstrating stylized and realistic art"
    ]
  }
];

const benefits = [
  {
    title: "Health & Wellness",
    description: "Comprehensive health coverage, mental health support, and wellness programs.",
    icon: "heart"
  },
  {
    title: "Learning & Growth",
    description: "Professional development budget, conference attendance, and mentorship programs.",
    icon: "academic-cap"
  },
  {
    title: "Work-Life Balance",
    description: "Flexible hours, remote work options, and generous paid time off.",
    icon: "clock"
  },
  {
    title: "Creative Freedom",
    description: "Autonomy to innovate and bring your ideas to life in our games.",
    icon: "light-bulb"
  }
];
---

<Layout title="Careers - Castaway Studios">
  <section class="pt-32 pb-20">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-6xl font-bold text-center mb-4">
        <span class="text-violet">Join</span>
        <span class="text-off-white"> Our Team</span>
      </h1>
      <p class="text-xl text-pink text-center mb-16 max-w-3xl mx-auto">
        Help us create the next generation of gaming experiences.
      </p>

      <!-- Benefits Section -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-12">
          <span class="text-violet">Why</span>
          <span class="text-off-white"> Join Us</span>
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {benefits.map((benefit) => (
            <div class="bg-lights-off/50 rounded-xl p-6 border border-violet/20 hover:border-violet/40 transition-colors">
              <div class="w-12 h-12 bg-violet/20 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-violet" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  {benefit.icon === "heart" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  )}
                  {benefit.icon === "academic-cap" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                  )}
                  {benefit.icon === "clock" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  )}
                  {benefit.icon === "light-bulb" && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  )}
                </svg>
              </div>
              <h3 class="text-xl font-bold text-off-white mb-2">{benefit.title}</h3>
              <p class="text-off-white/80">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Open Positions -->
      <div>
        <h2 class="text-3xl font-bold text-center mb-12">
          <span class="text-violet">Open</span>
          <span class="text-off-white"> Positions</span>
        </h2>
        
        <div class="space-y-6">
          {positions.map((position) => (
            <div class="bg-lights-off/50 rounded-xl p-6 border border-violet/20 hover:border-violet/40 transition-colors">
              <div class="flex flex-col md:flex-row md:items-center justify-between mb-4">
                <div>
                  <h3 class="text-2xl font-bold text-off-white">{position.title}</h3>
                  <p class="text-pink">{position.department}</p>
                </div>
                <div class="flex flex-wrap gap-4 mt-4 md:mt-0">
                  <span class="px-3 py-1 text-sm bg-violet/20 text-violet rounded-full">
                    {position.location}
                  </span>
                  <span class="px-3 py-1 text-sm bg-pink/20 text-pink rounded-full">
                    {position.type}
                  </span>
                </div>
              </div>
              
              <p class="text-off-white/80 mb-6">{position.description}</p>
              
              <div class="mb-6">
                <h4 class="text-lg font-semibold text-off-white mb-3">Requirements</h4>
                <ul class="space-y-2">
                  {position.requirements.map((req) => (
                    <li class="flex items-center text-off-white/80">
                      <svg class="w-4 h-4 mr-2 text-pumpkin" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {req}
                    </li>
                  ))}
                </ul>
              </div>
              
              <a 
                href={`/careers/${position.title.toLowerCase().replace(/\s+/g, '-')}`}
                class="inline-flex items-center text-pink hover:text-violet transition-colors"
              >
                Apply Now
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="h-5 w-5 ml-2" 
                  viewBox="0 0 20 20" 
                  fill="currentColor"
                >
                  <path 
                    fill-rule="evenodd" 
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" 
                    clip-rule="evenodd" 
                  />
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout> 