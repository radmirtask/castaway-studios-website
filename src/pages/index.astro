---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import { getCollection } from 'astro:content';

// Get games for preview
const games = await getCollection('games');
const featuredGames = games.slice(0, 3);

// Timeline data for development process
const timelineItems = [
  {
    title: "Concept & Design",
    description: "We start with innovative ideas and create compelling game concepts that push the boundaries of interactive entertainment.",
    date: "Week 1-2",
    icon: "💡"
  },
  {
    title: "Development",
    description: "Our expert team brings concepts to life using cutting-edge technology and proven development methodologies.",
    date: "Week 3-12",
    icon: "⚡"
  },
  {
    title: "Testing & Polish",
    description: "Rigorous testing and refinement ensure every game meets our high standards for quality and player experience.",
    date: "Week 13-16",
    icon: "🎯"
  },
  {
    title: "Launch",
    description: "Strategic launch campaigns and ongoing support help our games reach their full potential in the market.",
    date: "Week 17+",
    icon: "🚀"
  }
];
---

<Layout title="Castaway Studios - Visions of Tomorrow" description="Creating unforgettable gaming experiences with cutting-edge technology and creative storytelling. Discover our innovative games and join the future of interactive entertainment.">
  <!-- Hero Section with Video Background -->
  <section class="h-screen flex items-center justify-center relative overflow-hidden">
    <!-- Multi-Video Background - Desktop -->
    <div class="video-background absolute inset-0 z-0">
      <!-- Desktop Layout: 3 videos side by side -->
      <div class="hidden md:flex h-full video-container-3d">
        <!-- First video (left third) -->
        <div class="video-segment flex-1 relative">
          <video 
            autoplay 
            muted 
            loop 
            playsinline
            preload="auto"
            class="w-full h-full object-cover"
            style="transform: translateZ(0);"
            onloadstart="console.log('Video 1 loading started')"
            onloadeddata="console.log('Video 1 loaded')"
            onerror="console.log('Video 1 error', this.error)"
          >
            <source src="/videos/gameplay_mob.mp4#t=0" type="video/mp4">
            <source src="/videos/gameplay.mp4#t=0" type="video/mp4">
            Your browser does not support the video tag.
          </video>
          
          <!-- Electric Purple vertical separator bar -->
          <div class="separator-bar absolute top-0 right-0 h-full w-2 z-10" 
               style="background: linear-gradient(180deg, transparent 0%, #B316D5 20%, #B316D5 80%, transparent 100%); box-shadow: 0 0 20px #B316D5;">
          </div>
        </div>

        <!-- Second video (middle third) -->
        <div class="video-segment video-segment-middle flex-1 relative">
          <video 
            autoplay 
            muted 
            loop 
            playsinline
            preload="auto"
            class="w-full h-full object-cover middle-video-3d"
            style="transform: translateZ(0);"
            onloadstart="console.log('Video 2 loading started')"
            onloadeddata="console.log('Video 2 loaded')"
            onerror="console.log('Video 2 error', this.error)"
          >
            <source src="/videos/gameplay_mob.mp4#t=30" type="video/mp4">
            <source src="/videos/gameplay.mp4#t=30" type="video/mp4">
            Your browser does not support the video tag.
          </video>
          
          <!-- Enhanced glowing frame for middle video -->
          <div class="middle-video-frame absolute inset-0 pointer-events-none z-20"></div>
          
          <!-- Hibiscus Pink vertical separator bar -->
          <div class="separator-bar absolute top-0 right-0 h-full w-2 z-10" 
               style="background: linear-gradient(180deg, transparent 0%, #CD2373 20%, #CD2373 80%, transparent 100%); box-shadow: 0 0 20px #CD2373;">
          </div>
        </div>

        <!-- Third video (right third) -->
        <div class="video-segment flex-1 relative">
          <video 
            autoplay 
            muted 
            loop 
            playsinline
            preload="auto"
            class="w-full h-full object-cover"
            style="transform: translateZ(0);"
            onloadstart="console.log('Video 3 loading started')"
            onloadeddata="console.log('Video 3 loaded')"
            onerror="console.log('Video 3 error', this.error)"
          >
            <source src="/videos/gameplay_mob.mp4#t=60" type="video/mp4">
            <source src="/videos/gameplay.mp4#t=60" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        </div>

        <!-- Animated vertical accent bars for extra style -->
        <div class="accent-bar absolute h-full w-1 z-20 animate-pulse" 
             style="left: calc(33.33% - 1px); background: linear-gradient(180deg, #FFEE34 0%, #B316D5 50%, #CD2373 100%); opacity: 0.6;">
        </div>
        <div class="accent-bar absolute h-full w-1 z-20 animate-pulse" 
             style="left: calc(66.66% - 1px); background: linear-gradient(180deg, #CD2373 0%, #FFEE34 50%, #B316D5 100%); opacity: 0.6; animation-delay: 0.5s;">
        </div>
      </div>

      <!-- Mobile Layout: Single video -->
      <div class="md:hidden">
        <div class="video-segment absolute inset-0">
          <video 
            autoplay 
            muted 
            loop 
            playsinline
            preload="auto"
            class="w-full h-full object-cover"
            style="transform: translateZ(0);"
            onloadstart="console.log('Mobile video loading started')"
            onloadeddata="console.log('Mobile video loaded')"
            onerror="console.log('Mobile video error', this.error)"
          >
            <source src="/videos/gameplay_mob.mp4" type="video/mp4">
            <source src="/videos/gameplay.mp4" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        </div>
      </div>

      <!-- Dark overlay to ensure text readability -->
      <div class="absolute inset-0 bg-black/40 z-30"></div>
    </div>

    <!-- Content Layer -->
    <div class="content-layer container-custom relative z-40">
      <div class="text-center max-w-5xl mx-auto">
        <!-- Company Logo -->
        <div class="mb-8 animate-fade-in">
          <img 
            src="/ddAsset 3.svg" 
            alt="Castaway Studios" 
            class="h-20 md:h-32 w-auto mx-auto transition-all duration-300 hover:scale-110"
            style="filter: brightness(0) saturate(100%) invert(100%);"
          />
        </div>
        
        <!-- Yellow accent strip separator -->
        <div class="relative mb-8 animate-slide-up">
          <div class="h-1 bg-accent-yellow mx-auto max-w-md rounded-full shadow-glow-yellow"></div>
          <div class="absolute inset-0 h-1 bg-gradient-to-r from-transparent via-accent-yellow to-transparent mx-auto max-w-lg rounded-full blur-sm"></div>
        </div>
        
        <!-- Main Title -->
        <h2 class="heading-1 mb-8 text-gradient-violet-pink animate-slide-up hero-title-3d">
          VISIONS OF TOMORROW
        </h2>
        
        <!-- Description -->
        <p class="text-xl md:text-2xl mb-12 max-w-2xl mx-auto animate-slide-up hero-description-3d" style="color: #CD2373;">
          Crafting immersive gaming experiences that push the boundaries of creativity and innovation.
        </p>
        
        <!-- Action Buttons -->
        <div class="flex flex-col md:flex-row gap-4 justify-center animate-fade-in">
          <a href="/games" 
             class="px-8 py-3 font-semibold rounded-lg hover:scale-105 transition-all duration-300 hero-button-3d"
             style="background-color: #FFEE34; color: #1B031B;">
            View Our Games
          </a>
          <a href="/careers" 
             class="px-8 py-3 border-2 font-semibold rounded-lg transition-all duration-300 hover:scale-105 hero-button-3d-outline"
             style="border-color: #CD2373; color: #CD2373;"
             onmouseenter="this.style.backgroundColor='#CD2373'; this.style.color='#1B031B';"
             onmouseleave="this.style.backgroundColor='transparent'; this.style.color='#CD2373';">
            Join the Team
          </a>
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce z-40">
      <svg class="w-6 h-6 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Games Collection Section -->
  <section class="section-padding bg-background-primary">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-2 mb-4">GAME COLLECTION</h2>
        <p class="body-text-lg text-text-secondary max-w-2xl mx-auto">
          Discover our portfolio of innovative games that blend cutting-edge technology with compelling storytelling.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <!-- Game 1 - With Video Trailer -->
        <GameCard 
          title="Cosmic Voyager"
          video="/videos/gameplay_mob.mp4#t=0"
          href="/games/cosmic-voyager"
        />
        
        <!-- Game 2 - With Different Gameplay Video -->
        <GameCard 
          title="Neon Nights"
          video="/videos/gameplay_mob.mp4#t=30"
          href="/games/neon-nights"
        />
        
        <!-- Game 3 - With Another Gameplay Segment -->
        <GameCard 
          title="Mystic Realms"
          video="/videos/gameplay_mob.mp4#t=60"
          href="/games/mystic-realms"
        />
      </div>
      
      <div class="text-center">
        <a href="/games" class="btn-secondary">
          View All Games
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Development Process Timeline -->
  <ProcessTimeline 
    title="Our Development Process"
    subtitle="From initial concept to final launch, we follow a proven methodology that ensures every game reaches its full potential."
    items={timelineItems}
    className="bg-background-primary"
  />

  <!-- Call to Action Section -->
  <section class="section-padding bg-gradient-violet-pink relative overflow-hidden">
    <div class="container-custom relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <h2 class="heading-2 mb-6 text-text-primary">Ready to Create Something Amazing?</h2>
        <p class="body-text-lg text-text-primary/90 mb-8 max-w-2xl mx-auto">
          Join our team of passionate developers, designers, and storytellers. Together, we'll build the future of gaming.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/careers" class="btn-primary bg-text-primary text-background-primary hover:bg-text-secondary">
            View Open Positions
          </a>
          <a href="/contact" class="btn-secondary border-text-primary text-text-primary hover:bg-text-primary hover:text-background-primary">
            Get In Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="section-padding-sm bg-background-primary">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="group">
          <div class="text-4xl font-bold text-accent-yellow mb-2 group-hover:scale-110 transition-transform duration-300">10+</div>
          <div class="caption-text">Games Developed</div>
        </div>
        <div class="group">
          <div class="text-4xl font-bold text-accent-pink mb-2 group-hover:scale-110 transition-transform duration-300">50K+</div>
          <div class="caption-text">Players Worldwide</div>
        </div>
        <div class="group">
          <div class="text-4xl font-bold text-accent-violet mb-2 group-hover:scale-110 transition-transform duration-300">25+</div>
          <div class="caption-text">Team Members</div>
        </div>
        <div class="group">
          <div class="text-4xl font-bold text-accent-yellow mb-2 group-hover:scale-110 transition-transform duration-300">5</div>
          <div class="caption-text">Years Experience</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Force video playback and handle errors
  document.addEventListener('DOMContentLoaded', function() {
    const videos = document.querySelectorAll('video');
    
    videos.forEach((video, index) => {
      console.log(`Video ${index + 1} found:`, video);
      
      // Try to play the video
      const playPromise = video.play();
      
      if (playPromise !== undefined) {
        playPromise
          .then(() => {
            console.log(`Video ${index + 1} started playing successfully`);
          })
          .catch(error => {
            console.log(`Video ${index + 1} autoplay failed:`, error);
            
            // If autoplay fails, try playing on user interaction
            document.addEventListener('click', function() {
              video.play().catch(e => console.log(`Manual play failed for video ${index + 1}:`, e));
            }, { once: true });
          });
      }
      
      // Add error event listener
      video.addEventListener('error', function(e) {
        console.error(`Video ${index + 1} error:`, e);
        console.error('Video error details:', video.error);
      });
      
      // Add loaded event listener
      video.addEventListener('loadeddata', function() {
        console.log(`Video ${index + 1} loaded successfully`);
      });
    });
  });

  // Parallax effect for horizontal video segments
  function handleParallax() {
    const scrolled = window.pageYOffset;
    const contentLayer = document.querySelector('.content-layer') as HTMLElement;
    
    // Only apply parallax to the content layer (text) - videos stay static
    if (contentLayer) {
      const contentSpeed = scrolled * 0.4;
      contentLayer.style.transform = `translateY(${-contentSpeed}px)`;
    }
  }

  // Add scroll event listener
  window.addEventListener('scroll', handleParallax);
  
  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    window.removeEventListener('scroll', handleParallax);
  });
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slide-up {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }

  .animate-slide-up {
    animation: slide-up 1s ease-out 0.5s forwards;
    opacity: 0;
  }

  /* Hero 3D Text Effects */
  .hero-title-3d {
    text-shadow: 
      0 1px 0 rgba(179, 22, 213, 0.8),
      0 2px 0 rgba(179, 22, 213, 0.7),
      0 3px 0 rgba(179, 22, 213, 0.6),
      0 4px 0 rgba(179, 22, 213, 0.5),
      0 5px 0 rgba(179, 22, 213, 0.4),
      0 6px 0 rgba(179, 22, 213, 0.3),
      0 7px 0 rgba(179, 22, 213, 0.2),
      0 8px 0 rgba(179, 22, 213, 0.1),
      0 12px 20px rgba(0, 0, 0, 0.4),
      0 16px 30px rgba(0, 0, 0, 0.3);
    transform: perspective(1000px) rotateX(5deg);
    letter-spacing: 0.1em;
    filter: drop-shadow(0 0 20px rgba(179, 22, 213, 0.3));
  }

  .hero-description-3d {
    text-shadow: 
      0 1px 0 rgba(205, 35, 115, 0.6),
      0 2px 0 rgba(205, 35, 115, 0.5),
      0 3px 0 rgba(205, 35, 115, 0.4),
      0 4px 0 rgba(205, 35, 115, 0.3),
      0 6px 15px rgba(0, 0, 0, 0.3),
      0 8px 25px rgba(0, 0, 0, 0.2);
    transform: perspective(800px) rotateX(3deg);
    letter-spacing: 0.05em;
    filter: drop-shadow(0 0 15px rgba(205, 35, 115, 0.2));
  }

  .hero-button-3d {
    text-shadow: 
      0 1px 0 rgba(27, 3, 27, 0.8),
      0 2px 0 rgba(27, 3, 27, 0.6),
      0 3px 0 rgba(27, 3, 27, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.3);
    box-shadow: 
      0 4px 0 rgba(255, 238, 52, 0.8),
      0 8px 15px rgba(0, 0, 0, 0.3),
      0 12px 25px rgba(0, 0, 0, 0.2);
    transform: perspective(500px) rotateX(2deg);
    letter-spacing: 0.03em;
  }

  .hero-button-3d:hover {
    transform: perspective(500px) rotateX(2deg) translateY(-2px);
    box-shadow: 
      0 6px 0 rgba(255, 238, 52, 0.8),
      0 12px 20px rgba(0, 0, 0, 0.4),
      0 16px 30px rgba(0, 0, 0, 0.3);
  }

  .hero-button-3d-outline {
    text-shadow: 
      0 1px 0 rgba(205, 35, 115, 0.6),
      0 2px 0 rgba(205, 35, 115, 0.4),
      0 3px 8px rgba(0, 0, 0, 0.3);
    box-shadow: 
      0 4px 0 rgba(205, 35, 115, 0.6),
      0 8px 15px rgba(0, 0, 0, 0.3),
      0 12px 25px rgba(0, 0, 0, 0.2);
    transform: perspective(500px) rotateX(2deg);
    letter-spacing: 0.03em;
  }

  .hero-button-3d-outline:hover {
    transform: perspective(500px) rotateX(2deg) translateY(-2px);
    box-shadow: 
      0 6px 0 rgba(205, 35, 115, 0.8),
      0 12px 20px rgba(0, 0, 0, 0.4),
      0 16px 30px rgba(0, 0, 0, 0.3);
  }

  /* Ensure video segments cover their areas */
  .video-segment {
    /* Static positioning - no movement effects */
  }
  
  .separator-bar {
    /* Static positioning - no movement effects */
  }

  .accent-bar {
    /* Static positioning - no movement effects */
  }
  
  .content-layer {
    will-change: transform;
  }

  /* Smooth hardware acceleration */
  .video-segment video {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  /* Custom pulse animation for accent bars */
  @keyframes pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.9; }
  }

  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* 3D Effect for Middle Video */
  .video-container-3d {
    perspective: 1200px;
    perspective-origin: center center;
    transform-style: preserve-3d;
  }

  .video-segment-middle {
    perspective: 1000px;
    transform-style: preserve-3d;
    z-index: 30;
  }

  .middle-video-3d {
    transform: perspective(1000px) rotateY(0deg) translateZ(50px) scale(1.05);
    box-shadow: 
      0 25px 50px rgba(0, 0, 0, 0.6),
      0 15px 30px rgba(179, 22, 213, 0.3),
      0 10px 20px rgba(205, 35, 115, 0.2),
      inset 0 0 0 2px rgba(255, 238, 52, 0.1);
    border-radius: 8px;
    transition: all 0.5s ease;
    filter: 
      brightness(1.1) 
      contrast(1.1) 
      saturate(1.1)
      drop-shadow(0 0 30px rgba(179, 22, 213, 0.4));
  }

  .middle-video-3d:hover {
    transform: perspective(1000px) rotateY(2deg) translateZ(70px) scale(1.08);
    box-shadow: 
      0 35px 70px rgba(0, 0, 0, 0.8),
      0 20px 40px rgba(179, 22, 213, 0.5),
      0 15px 30px rgba(205, 35, 115, 0.3),
      inset 0 0 0 3px rgba(255, 238, 52, 0.2);
    filter: 
      brightness(1.2) 
      contrast(1.15) 
      saturate(1.2)
      drop-shadow(0 0 40px rgba(179, 22, 213, 0.6));
  }

  .middle-video-frame {
    background: linear-gradient(45deg, 
      rgba(179, 22, 213, 0.3) 0%, 
      rgba(205, 35, 115, 0.3) 25%, 
      rgba(255, 238, 52, 0.2) 50%, 
      rgba(205, 35, 115, 0.3) 75%, 
      rgba(179, 22, 213, 0.3) 100%);
    background-size: 400% 400%;
    animation: gradientFrameFlow 4s ease-in-out infinite;
    border-radius: 8px;
    box-shadow: 
      inset 0 0 30px rgba(179, 22, 213, 0.3),
      inset 0 0 20px rgba(205, 35, 115, 0.2),
      0 0 50px rgba(179, 22, 213, 0.3);
  }

  @keyframes gradientFrameFlow {
    0% {
      background-position: 0% 50%;
      box-shadow: 
        inset 0 0 30px rgba(179, 22, 213, 0.3),
        inset 0 0 20px rgba(205, 35, 115, 0.2),
        0 0 50px rgba(179, 22, 213, 0.3);
    }
    25% {
      background-position: 100% 0%;
      box-shadow: 
        inset 0 0 30px rgba(205, 35, 115, 0.4),
        inset 0 0 20px rgba(255, 238, 52, 0.2),
        0 0 60px rgba(205, 35, 115, 0.4);
    }
    50% {
      background-position: 100% 100%;
      box-shadow: 
        inset 0 0 30px rgba(255, 238, 52, 0.3),
        inset 0 0 20px rgba(179, 22, 213, 0.2),
        0 0 50px rgba(255, 238, 52, 0.3);
    }
    75% {
      background-position: 0% 100%;
      box-shadow: 
        inset 0 0 30px rgba(205, 35, 115, 0.4),
        inset 0 0 20px rgba(179, 22, 213, 0.2),
        0 0 60px rgba(205, 35, 115, 0.4);
    }
    100% {
      background-position: 0% 50%;
      box-shadow: 
        inset 0 0 30px rgba(179, 22, 213, 0.3),
        inset 0 0 20px rgba(205, 35, 115, 0.2),
        0 0 50px rgba(179, 22, 213, 0.3);
    }
  }

  /* Adjust other video segments to be slightly receded */
  .video-segment:not(.video-segment-middle) {
    transform: translateZ(-10px);
    filter: brightness(0.9) contrast(0.95);
    transition: all 0.3s ease;
  }

  .video-segment:not(.video-segment-middle):hover {
    transform: translateZ(0px);
    filter: brightness(1) contrast(1);
  }

  /* Ensure middle video maintains higher z-index */
  .video-segment-middle {
    position: relative;
    z-index: 30;
  }

  /* Responsive adjustments for 3D effect */
  @media (max-width: 768px) {
    .middle-video-3d {
      transform: perspective(800px) rotateY(0deg) translateZ(20px) scale(1.02);
    }
    
    .middle-video-3d:hover {
      transform: perspective(800px) rotateY(1deg) translateZ(30px) scale(1.04);
    }
  }
</style>
