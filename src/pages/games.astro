---
import Layout from '../layouts/Layout.astro';

const games = [
  {
    title: "Cosmic Voyager",
    description: "An epic space adventure where you explore the unknown reaches of the universe.",
    longDescription: "Embark on an interstellar journey through procedurally generated galaxies. Discover ancient civilizations, trade with alien species, and build your own space empire. With stunning visuals and deep gameplay mechanics, Cosmic Voyager offers an unparalleled space exploration experience.",
    image: "/images/cosmic-voyager.jpg",
    features: ["Open World Exploration", "Space Trading", "Combat System", "Crew Management"],
    status: "In Development",
    releaseDate: "Q4 2024"
  },
  {
    title: "Neon Nights",
    description: "A cyberpunk action RPG set in a neon-lit dystopian future.",
    longDescription: "Navigate the neon-soaked streets of Neo-Tokyo in this action-packed RPG. Hack into corporate systems, engage in high-stakes combat, and uncover the dark secrets of the city's ruling class. With its unique blend of cyberpunk aesthetics and deep storytelling, Neon Nights offers an immersive gaming experience.",
    image: "/images/neon-nights.jpg",
    features: ["Cyberpunk Setting", "Hacking Mechanics", "Character Customization", "Branching Storylines"],
    status: "Alpha Testing",
    releaseDate: "Q2 2025"
  },
  {
    title: "Mystic Realms",
    description: "A fantasy RPG where magic and mystery await at every turn.",
    longDescription: "Enter a world of ancient magic and mythical creatures. As a young apprentice, master the arcane arts, forge alliances with magical beings, and uncover the secrets of the ancient wizards. With its rich lore and dynamic magic system, Mystic Realms brings fantasy to life.",
    image: "/images/mystic-realms.jpg",
    features: ["Magic System", "Creature Companions", "Dungeon Crawling", "Crafting"],
    status: "Pre-Alpha",
    releaseDate: "TBA"
  }
];
---

<Layout title="Our Games - Castaway Studios">
  <section class="pt-32 pb-20">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-6xl font-bold text-center mb-4">
        <span class="text-violet">Our</span>
        <span class="text-off-white"> Games</span>
      </h1>
      <p class="text-xl text-pink text-center mb-16 max-w-3xl mx-auto">
        Discover our upcoming titles and join us on these extraordinary adventures.
      </p>

      <div class="space-y-32">
        {games.map((game, index) => (
          <div class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-12 items-center`}>
            <div class="lg:w-1/2">
              <div class="relative rounded-xl overflow-hidden aspect-video">
                <div class="absolute inset-0 bg-gradient-to-br from-violet/20 to-pink/20"></div>
                <img 
                  src={game.image} 
                  alt={game.title}
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
            
            <div class="lg:w-1/2">
              <div class="flex items-center gap-4 mb-4">
                <h2 class="text-3xl font-bold text-off-white">{game.title}</h2>
                <span class="px-3 py-1 text-sm font-semibold bg-violet/20 text-violet rounded-full">
                  {game.status}
                </span>
              </div>
              
              <p class="text-off-white/80 mb-6">{game.longDescription}</p>
              
              <div class="mb-6">
                <h3 class="text-lg font-semibold text-pink mb-3">Key Features</h3>
                <ul class="grid grid-cols-2 gap-2">
                  {game.features.map((feature) => (
                    <li class="flex items-center text-off-white/80">
                      <svg class="w-4 h-4 mr-2 text-pumpkin" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
              
              <div class="flex items-center gap-4">
                <span class="text-off-white/60">Release Date: {game.releaseDate}</span>
                <a 
                  href={`/games/${game.title.toLowerCase().replace(' ', '-')}`}
                  class="inline-flex items-center text-pink hover:text-violet transition-colors"
                >
                  Learn More
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class="h-5 w-5 ml-2" 
                    viewBox="0 0 20 20" 
                    fill="currentColor"
                  >
                    <path 
                      fill-rule="evenodd" 
                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" 
                      clip-rule="evenodd" 
                    />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
