---
const games = [
  {
    title: "Cosmic Voyager",
    description: "An epic space adventure where you explore the unknown reaches of the universe.",
    image: "/images/cosmic-voyager.jpg",
    link: "/games/cosmic-voyager"
  },
  {
    title: "Neon Nights",
    description: "A cyberpunk action RPG set in a neon-lit dystopian future.",
    image: "/images/neon-nights.jpg",
    link: "/games/neon-nights"
  },
  {
    title: "Mystic Realms",
    description: "A fantasy RPG where magic and mystery await at every turn.",
    image: "/images/mystic-realms.jpg",
    link: "/games/mystic-realms"
  }
];
---

<section class="py-20 bg-lights-off">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      <span class="text-violet">Our</span>
      <span class="text-off-white"> Games</span>
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {games.map((game) => (
        <div class="group relative bg-lights-off/50 rounded-xl overflow-hidden border border-violet/20 hover:border-violet/40 transition-colors">
          <div class="aspect-video bg-gradient-to-br from-violet/20 to-pink/20 relative">
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors"></div>
            <img 
              src={game.image} 
              alt={game.title}
              class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
            />
          </div>
          
          <div class="p-6">
            <h3 class="text-xl font-bold text-off-white mb-2">{game.title}</h3>
            <p class="text-off-white/80 mb-4">{game.description}</p>
            <a 
              href={game.link}
              class="inline-flex items-center text-pink hover:text-violet transition-colors"
            >
              View Details
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" 
                viewBox="0 0 20 20" 
                fill="currentColor"
              >
                <path 
                  fill-rule="evenodd" 
                  d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" 
                  clip-rule="evenodd" 
                />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section> 