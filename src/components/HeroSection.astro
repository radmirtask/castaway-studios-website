---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  backgroundImage?: string;
  className?: string;
}

const { 
  title, 
  subtitle, 
  description, 
  primaryButtonText = "Get Started",
  primaryButtonHref = "#",
  secondaryButtonText = "Learn More",
  secondaryButtonHref = "#",
  backgroundImage,
  className = '' 
} = Astro.props;
---

<section class={`relative min-h-screen flex items-center justify-center overflow-hidden ${className}`}>
  <!-- Background -->
  <div class="absolute inset-0 bg-background-primary">
    {backgroundImage && (
      <div class="absolute inset-0">
        <img 
          src={backgroundImage} 
          alt="" 
          class="w-full h-full object-cover opacity-20"
        />
        <div class="absolute inset-0 bg-gradient-dark-overlay"></div>
      </div>
    )}
  </div>
  
  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-accent-violet/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-pink/10 rounded-full blur-3xl animate-float" style="animation-delay: -1s;"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-128 h-128 bg-accent-yellow/5 rounded-full blur-3xl animate-float" style="animation-delay: -2s;"></div>
  </div>
  
  <!-- Content -->
  <div class="container-custom relative z-10">
    <div class="text-center max-w-5xl mx-auto">
      <!-- Subtitle -->
      {subtitle && (
        <div class="mb-6">
          <span class="inline-block bg-accent-yellow text-text-on-yellow px-6 py-2 rounded-full text-sm font-medium uppercase tracking-wider">
            {subtitle}
          </span>
        </div>
      )}
      
      <!-- Main Title -->
      <h1 class="heading-1 mb-8 text-gradient-violet-pink animate-glow">
        {title}
      </h1>
      
      <!-- Yellow accent strip -->
      <div class="relative mb-8">
        <div class="h-1 bg-accent-yellow mx-auto max-w-md rounded-full shadow-glow-yellow"></div>
        <div class="absolute inset-0 h-1 bg-gradient-to-r from-transparent via-accent-yellow to-transparent mx-auto max-w-lg rounded-full blur-sm"></div>
      </div>
      
      <!-- Description -->
      {description && (
        <p class="body-text-lg text-text-secondary mb-12 max-w-3xl mx-auto leading-relaxed">
          {description}
        </p>
      )}
      
      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href={primaryButtonHref} class="btn-primary group">
          {primaryButtonText}
          <svg class="w-5 h-5 ml-2 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        
        <a href={secondaryButtonHref} class="btn-secondary group">
          {secondaryButtonText}
          <svg class="w-5 h-5 ml-2 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
      </div>
      
      <!-- Play button (if needed) -->
      <div class="mt-12">
        <button class="group relative w-20 h-20 bg-accent-pink rounded-full flex items-center justify-center shadow-glow-pink hover:shadow-glow-pink hover:scale-110 transition-all duration-300">
          <svg class="w-8 h-8 text-text-primary ml-1 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <div class="absolute inset-0 rounded-full bg-accent-pink animate-ping opacity-20"></div>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section> 