---
import '../styles/global.css';
import Nav from '../components/Nav.jsx';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Creating unforgettable gaming experiences with cutting-edge technology and creative storytelling." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" x-data="{ mobileMenu: false }" x-cloak>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Meta tags for social sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  
  <body class="bg-background-primary text-text-primary min-h-screen antialiased">
    <!-- Navigation -->
    <Nav client:load />

    <!-- Main Content -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 border-t border-accent-violet/20 bg-background-primary">
      <div class="container-custom section-padding">
        <!-- Main Footer Content -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
          <!-- Company Info -->
          <div class="lg:col-span-2">
            <h3 class="heading-3 mb-6 text-gradient-violet-pink">GET IN TOUCH</h3>
            <p class="body-text text-text-secondary mb-6 max-w-md">
              Creating unforgettable gaming experiences with cutting-edge technology and creative storytelling.
            </p>
            
            <!-- Newsletter Signup -->
            <div class="flex flex-col sm:flex-row gap-3">
              <input 
                type="email" 
                placeholder="Enter your email" 
                class="input-field flex-1"
              />
              <button class="btn-primary whitespace-nowrap">
                Subscribe
              </button>
            </div>
          </div>
          
          <!-- Company Links -->
          <div>
            <h4 class="heading-4 mb-4 text-text-primary">Company</h4>
            <ul class="space-y-3">
              <li><a href="/about" class="nav-link text-text-secondary hover:text-accent-yellow">About Us</a></li>
              <li><a href="/team" class="nav-link text-text-secondary hover:text-accent-yellow">Our Team</a></li>
              <li><a href="/careers" class="nav-link text-text-secondary hover:text-accent-yellow">Careers</a></li>
              <li><a href="/press" class="nav-link text-text-secondary hover:text-accent-yellow">Press</a></li>
            </ul>
          </div>
          
          <!-- Help Links -->
          <div>
            <h4 class="heading-4 mb-4 text-text-primary">Help</h4>
            <ul class="space-y-3">
              <li><a href="/support" class="nav-link text-text-secondary hover:text-accent-yellow">Support</a></li>
              <li><a href="/contact" class="nav-link text-text-secondary hover:text-accent-yellow">Contact</a></li>
              <li><a href="/privacy" class="nav-link text-text-secondary hover:text-accent-yellow">Privacy Policy</a></li>
              <li><a href="/terms" class="nav-link text-text-secondary hover:text-accent-yellow">Terms of Service</a></li>
            </ul>
          </div>
        </div>
        
        <!-- Social Media -->
        <div class="flex justify-center space-x-6 mb-8">
          <a href="#" class="group p-3 rounded-full bg-accent-violet/10 hover:bg-accent-violet transition-all duration-300">
            <svg class="w-6 h-6 text-accent-violet group-hover:text-text-primary transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
            </svg>
          </a>
          
          <a href="#" class="group p-3 rounded-full bg-accent-pink/10 hover:bg-accent-pink transition-all duration-300">
            <svg class="w-6 h-6 text-accent-pink group-hover:text-text-primary transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
            </svg>
          </a>
          
          <a href="#" class="group p-3 rounded-full bg-accent-yellow/10 hover:bg-accent-yellow transition-all duration-300">
            <svg class="w-6 h-6 text-accent-yellow group-hover:text-text-on-yellow transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"></path>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Copyright Bar -->
      <div class="bg-text-primary text-background-primary py-4">
        <div class="container-custom">
          <div class="flex flex-col md:flex-row justify-between items-center text-sm">
            <p>&copy; {new Date().getFullYear()} Castaway Studios. All rights reserved.</p>
            <div class="flex space-x-6 mt-2 md:mt-0">
              <a href="/privacy" class="hover:text-accent-pink transition-colors duration-300">Privacy</a>
              <a href="/terms" class="hover:text-accent-pink transition-colors duration-300">Terms</a>
              <a href="/cookies" class="hover:text-accent-pink transition-colors duration-300">Cookies</a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html> 