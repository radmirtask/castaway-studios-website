<script>
  // Parallax effect for horizontal video segments
  function handleParallax() {
    const scrolled = window.pageYOffset;
    const videoSegments = document.querySelectorAll('.video-segment') as NodeListOf<HTMLElement>;
    const separatorBars = document.querySelectorAll('.separator-bar') as NodeListOf<HTMLElement>;
    const accentBars = document.querySelectorAll('.accent-bar') as NodeListOf<HTMLElement>;
    const contentLayer = document.querySelector('.content-layer') as HTMLElement;
    
    if (videoSegments.length > 0 && contentLayer) {
      // Different parallax speeds for each video segment
      videoSegments.forEach((segment, index) => {
        const speed = 0.2 + (index * 0.1); // Different speeds: 0.2, 0.3, 0.4
        const videoSpeed = scrolled * speed;
        segment.style.transform = `translateY(${videoSpeed}px)`;
      });

      // Vertical separator bars move at different speed
      separatorBars.forEach((bar, index) => {
        const speed = 0.15 + (index * 0.05);
        const barSpeed = scrolled * speed;
        bar.style.transform = `translateY(${barSpeed}px)`;
      });

      // Vertical accent bars with slight movement
      accentBars.forEach((bar, index) => {
        const speed = 0.1 + (index * 0.02);
        const accentSpeed = scrolled * speed;
        bar.style.transform = `translateY(${accentSpeed}px)`;
      });
      
      // Content moves at normal speed but with slight offset for depth
      const contentSpeed = scrolled * 0.1;
      contentLayer.style.transform = `translateY(${-contentSpeed}px)`;
    }
  }

  // Add scroll event listener
  window.addEventListener('scroll', handleParallax);
  
  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    window.removeEventListener('scroll', handleParallax);
  });
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slide-up {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }

  .animate-slide-up {
    animation: slide-up 1s ease-out 0.5s forwards;
    opacity: 0;
  }

  /* Ensure video segments cover their areas */
  .video-segment {
    will-change: transform;
  }
  
  .separator-bar {
    will-change: transform;
  }

  .accent-bar {
    will-change: transform;
  }
  
  .content-layer {
    will-change: transform;
  }

  /* Smooth hardware acceleration */
  .video-segment video {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  /* Custom pulse animation for accent bars */
  @keyframes pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.9; }
  }

  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style> 