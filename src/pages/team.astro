---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Load all team profiles; Astro will infer CollectionEntry<'team'>[]
const team = await getCollection('team');
---
<BaseLayout title="Team – Castaway Studios">
  <h1 class="text-3xl font-bold text-center my-8">Meet the Team</h1>
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map((member) => (
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img
            src={member.data.photo}
            alt={member.data.name}
            class="w-full h-56 object-cover"
          />
          <div class="p-6">
            <h2 class="text-2xl font-semibold">{member.data.name}</h2>
            <p class="text-gray-600 mb-4">{member.data.role}</p>
            <div class="prose mb-4">
              {member.body}
            </div>
            <div class="flex space-x-4">
              {member.data.social?.linkedin && (
                <a
                  href={member.data.social.linkedin}
                  class="hover:text-blue-700"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  LinkedIn
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
